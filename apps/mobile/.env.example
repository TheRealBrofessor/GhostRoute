# All mobile env vars are EXPO_PUBLIC_* (compiled into the client bundle —
# never put server secrets here). Copy to .env for local overrides.

# Backend base URL for Emergency Share. Use your machine's LAN IP when testing
# on a physical phone (e.g. http://192.168.1.20:3000).
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# Routing/geocoding provider: "demo" (default, no API key needed) or "mapbox"
# (skeleton only — falls back to demo unless implemented and a token is set).
EXPO_PUBLIC_ROUTE_PROVIDER=demo

# Only needed if EXPO_PUBLIC_ROUTE_PROVIDER=mapbox. Get one at mapbox.com.
# EXPO_PUBLIC_MAPBOX_TOKEN=
